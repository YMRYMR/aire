<UserControl x:Class="Aire.UI.Controls.OllamaModelPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>

        <!-- ── Checking ── -->
        <StackPanel x:Name="CheckingPanel">
            <ProgressBar IsIndeterminate="True" Height="3" Margin="0 4 0 6" />
            <TextBlock Text="Checking Ollama on your machine..."
                       Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- ── Not installed ── -->
        <StackPanel x:Name="NotInstalledPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource Surface2Brush}"
                    CornerRadius="6" Padding="14" Margin="0 0 0 10">
                <StackPanel>
                    <TextBlock Text="Ollama runs AI models locally on your computer."
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               Margin="0 0 0 6" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run>Free and open source, no API key needed</Run><LineBreak />
                        <Run>Your data stays on your machine, never sent to the cloud</Run><LineBreak />
                        <Run>Works offline once a model is downloaded</Run>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border x:Name="SpecsBorder"
                    Background="{DynamicResource Surface3Brush}"
                    CornerRadius="6" Padding="10 8" Margin="0 0 0 8">
                <TextBlock x:Name="SpecsText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </Border>
            <Border x:Name="WarningBorder" Visibility="Collapsed"
                    Background="{DynamicResource Surface2Brush}"
                    BorderBrush="#E59A00" BorderThickness="2 1 1 1"
                    CornerRadius="4" Padding="10 8" Margin="0 0 0 10">
                <TextBlock x:Name="WarningText"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextBrush}" />
            </Border>
            <Button x:Name="InstallBtn" Height="38" Margin="0 2 0 6" Click="InstallBtn_Click">
                <TextBlock Text="Download &amp; Install Ollama  (free, ~700 MB)"
                           VerticalAlignment="Center" />
            </Button>
            <ProgressBar x:Name="InstallBar" Visibility="Collapsed"
                         IsIndeterminate="True" Height="4" Margin="0 0 0 4" />
            <TextBlock x:Name="InstallStatusText"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- ── Installed but not running ── -->
        <StackPanel x:Name="NotRunningPanel" Visibility="Collapsed">
            <Border Background="{DynamicResource Surface2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12" Margin="0 0 0 10">
                <StackPanel>
                    <TextBlock Text="Ollama is installed but not running."
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0 0 0 4" />
                    <TextBlock Text="Starting it automatically..."
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
            <ProgressBar IsIndeterminate="True" Height="3" Margin="0 0 0 6" />
            <Button x:Name="RetryBtn" Content="Retry" Height="30" Width="80"
                    HorizontalAlignment="Left" Margin="0 4 0 0" Click="RetryBtn_Click" />
        </StackPanel>

        <!-- ── Ready ── -->
        <StackPanel x:Name="ReadyPanel" Visibility="Collapsed">
            <TextBlock x:Name="ReadyText" FontWeight="SemiBold" Margin="0 0 0 10"
                       Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" />

            <TextBlock x:Name="LabelModel" Text="Choose a model:"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0 0 0 4" />

            <Grid Margin="0 0 0 4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ModelCombo" Grid.Column="0"
                          IsEditable="True" IsTextSearchEnabled="False"
                          MaxDropDownHeight="300" Height="34"
                          SelectionChanged="ModelCombo_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Prefix}" Width="14"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding ModelName}" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SizeStr}" Margin="5 0 0 0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TagsText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="4 0 0 0" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button x:Name="RefreshBtn" Grid.Column="1"
                        Content="↻" ToolTip="Refresh model list from Ollama"
                        Width="34" Height="34" Padding="0" Margin="4 0 0 0"
                        Click="RefreshBtn_Click" />
                <!-- DownloadBtn and UninstallBtn share the same column — only one is visible at a time -->
                <Button x:Name="DownloadBtn" Grid.Column="2"
                        Content="⬇" ToolTip="Download this model from Ollama"
                        Width="34" Height="34" Padding="0" Margin="4 0 0 0"
                        Visibility="Collapsed" IsEnabled="False"
                        Click="DownloadBtn_Click" />
                <Button x:Name="UninstallBtn" Grid.Column="2"
                        Content="🗑" ToolTip="Uninstall selected Ollama model"
                        Width="34" Height="34" Padding="0" Margin="4 0 0 0"
                        Visibility="Collapsed" IsEnabled="False"
                        Click="UninstallBtn_Click" />
                <Button x:Name="ImportBtn" Grid.Column="3"
                        Content="…" ToolTip="Import custom models from a JSON file"
                        Width="34" Height="34" Padding="0" Margin="4 0 0 0"
                        Visibility="Collapsed"
                        Click="ImportBtn_Click" />
            </Grid>

            <TextBlock x:Name="ModelHint"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0 0 0 6" />

            <TextBlock x:Name="LegendText"
                       Text="✓ = installed  ·  ★ = recommended for this PC and for Aire  ·  Type to filter."
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0 0 0 8" />

            <Border x:Name="DownloadProgressBorder" Visibility="Collapsed" Margin="0 4 0 4">
                <StackPanel>
                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DownloadProgressText"
                                   Grid.Column="0"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="CancelDownloadBtn"
                                Grid.Column="1"
                                Content="✕ Cancel"
                                FontSize="11"
                                Height="22" Padding="6 0"
                                Margin="8 0 0 0"
                                Click="CancelDownloadBtn_Click" />
                    </Grid>
                    <ProgressBar x:Name="DownloadProgressBar"
                                 Height="6" Minimum="0" Maximum="100" Value="0" />
                </StackPanel>
            </Border>

        </StackPanel>

    </StackPanel>
</UserControl>
