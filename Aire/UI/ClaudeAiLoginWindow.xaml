<Window x:Class="Aire.UI.ClaudeAiLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login with Claude.ai — Aire"
        Height="700" Width="520"
        MinHeight="500" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#18191E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2028" Padding="12 10">
            <TextBlock Text="Sign in to claude.ai. Aire will automatically detect when you are logged in and close this window."
                       Foreground="#9CA3AF" FontSize="12" TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="1" x:Name="WebViewHost" />

        <Border Grid.Row="2" Background="#1F2028" Padding="12 8">
            <TextBlock x:Name="StatusText" Text="Waiting for login…"
                       Foreground="#6B7280" FontSize="11" />
        </Border>
    </Grid>
</Window>
