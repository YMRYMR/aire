<Window
    x:Class="Aire.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Aire.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingsControls="clr-namespace:Aire.UI.Settings.Controls"
    Title="Settings — Aire"
    Width="760"
    Height="880"
    MinWidth="620"
    MinHeight="580"
    Background="{DynamicResource BackgroundBrush}"
    FontSize="13"
    Icon="/aire.ico"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="4"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border
        Background="{DynamicResource BackgroundBrush}"
        BorderBrush="{DynamicResource AccentBorderBrush}"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ── Title bar ──  -->
            <Border
                Grid.Row="0"
                Padding="12,10"
                Background="{DynamicResource AccentSurfaceBrush}"
                BorderBrush="{DynamicResource AccentBorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="TitleText"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource AccentTextBrush}"
                        Text="Settings — Aire" />
                    <Button
                        x:Name="CloseButton"
                        Grid.Column="1"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Click="CloseButton_Click"
                        Content="&#x2715;"
                        ToolTip="Close" />
                </Grid>
            </Border>

            <!--  ── Tabs ──  -->
            <TabControl
                x:Name="MainTabControl"
                Grid.Row="1"
                Margin="16"
                Background="{DynamicResource BackgroundBrush}"
                BorderThickness="0"
                SelectionChanged="TabControl_SelectionChanged">

                <!--  ══ Providers tab ══  -->
                <TabItem x:Name="TabProviders" Header="AI Providers">
                    <Grid x:Name="ProvidersColumnsGrid" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="150" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition
                                x:Name="EditPanelColumn"
                                Width="*"
                                MinWidth="180" />
                        </Grid.ColumnDefinitions>

                        <!--  Splitter between list and edit panel  -->
                        <GridSplitter
                            x:Name="ProvidersSplitter"
                            Grid.Column="1"
                            Width="5"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="{DynamicResource BorderBrush}"
                            Cursor="SizeWE"
                            DragCompleted="ProvidersSplitter_DragCompleted"
                            ResizeBehavior="PreviousAndNext"
                            ResizeDirection="Columns" />

                        <settingsControls:ProviderListPaneControl x:Name="ProviderListPaneControl" Grid.Column="0" />

                        <!--  RIGHT: edit form  -->
                        <Border
                            Grid.Column="2"
                            Padding="16"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <!--  thin loading bar at top, hidden when idle  -->
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  indeterminate bar shown while a provider is loading  -->
                                <ProgressBar
                                    x:Name="ProviderLoadingBar"
                                    Grid.Row="0"
                                    Height="3"
                                    Margin="-16,-16,-16,8"
                                    VerticalAlignment="Top"
                                    IsIndeterminate="True"
                                    Visibility="Collapsed" />

                                <ScrollViewer
                                    x:Name="EditFormScrollViewer"
                                    Grid.Row="1"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <!--  Row 12: separator  -->
                                            <RowDefinition Height="Auto" />
                                            <!--  Row 13: Run Tests button row  -->
                                            <RowDefinition Height="Auto" />
                                            <!--  Row 14: progress while running  -->
                                            <RowDefinition Height="Auto" />
                                            <!--  Row 15: results panel  -->
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            x:Name="EditPanelTitle"
                                            Grid.Row="0"
                                            Margin="0,0,0,14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextBrush}"
                                            Text="Select a provider" />

                                        <TextBlock
                                            x:Name="NameLabel"
                                            Grid.Row="1"
                                            Margin="0,0,0,4"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="Name" />
                                        <TextBox
                                            x:Name="NameTextBox"
                                            Grid.Row="2"
                                            Margin="0,0,0,10"
                                            IsEnabled="False"
                                            LostFocus="AutoSave" />

                                        <TextBlock
                                            x:Name="TypeLabel"
                                            Grid.Row="3"
                                            Margin="0,0,0,4"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="Type" />
                                        <ComboBox
                                            x:Name="TypeComboBox"
                                            Grid.Row="4"
                                            Margin="0,0,0,10"
                                            IsEnabled="False"
                                            SelectionChanged="TypeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="OpenAI" Tag="OpenAI" />
                                            <ComboBoxItem Content="Groq (free tier, fast)" Tag="Groq" />
                                            <ComboBoxItem Content="OpenRouter (100+ models, free tier)" Tag="OpenRouter" />
                                            <ComboBoxItem Content="Codex (local CLI bridge)" Tag="Codex" />
                                            <ComboBoxItem Content="Claude Code (local CLI bridge)" Tag="ClaudeCode" />
                                            <ComboBoxItem Content="Google AI" Tag="GoogleAI" />
                                            <ComboBoxItem Content="Google AI Images" Tag="GoogleAIImage" />
                                            <ComboBoxItem Content="Anthropic API" Tag="Anthropic" />
                                            <ComboBoxItem Content="Claude.ai" Tag="ClaudeWeb" />
                                            <ComboBoxItem Content="Ollama" Tag="Ollama" />
                                            <ComboBoxItem Content="DeepSeek (OpenAI‑compatible)" Tag="DeepSeek" />
                                            <ComboBoxItem Content="Mistral AI (OpenAI-compatible)" Tag="Mistral" />
                                            <ComboBoxItem Content="Inception (OpenAI‑compatible)" Tag="Inception" />
                                            <ComboBoxItem Content="Zhipu AI (OpenAI‑compatible)" Tag="Zai" />
                                        </ComboBox>

                                        <!--  Ollama model picker (shown only when Ollama type is selected)  -->
                                        <controls:OllamaModelPickerControl
                                            x:Name="OllamaModelPicker"
                                            Grid.Row="5"
                                            Margin="0,0,0,10"
                                            Visibility="Collapsed" />

                                        <TextBlock
                                            x:Name="ModelLabel"
                                            Grid.Row="6"
                                            Margin="0,0,0,4"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="Model" />
                                        <!--  Non-Ollama model picker (hidden when Ollama type is selected)  -->
                                        <Grid
                                            x:Name="NonOllamaModelArea"
                                            Grid.Row="7"
                                            Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox
                                                x:Name="ModelComboBox"
                                                Grid.Column="0"
                                                DisplayMemberPath="DisplayName"
                                                IsEditable="True"
                                                IsEnabled="True"
                                                LostFocus="AutoSave"
                                                SelectedValuePath="ModelName"
                                                SelectionChanged="ModelComboBox_SelectionChanged" />
                                            <Button
                                                x:Name="RefreshModelsButton"
                                                Grid.Column="1"
                                                Width="34"
                                                Height="34"
                                                Margin="4,0,0,0"
                                                Padding="0"
                                                Click="RefreshModelsButton_Click"
                                                Content="↻"
                                                IsEnabled="False"
                                                ToolTip="Refresh model list from server"
                                                Visibility="Collapsed" />
                                        </Grid>

                                        <TextBlock
                                            x:Name="ApiKeyLabel"
                                            Grid.Row="9"
                                            Margin="0,0,0,4"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="API Key" />
                                        <StackPanel Grid.Row="10" Margin="0,0,0,10">
                                            <PasswordBox
                                                x:Name="ApiKeyPasswordBox"
                                                Margin="0,0,0,6"
                                                IsEnabled="False"
                                                LostFocus="AutoSave" />
                                            <TextBlock
                                                x:Name="AnthropicKeyHint"
                                                Margin="0,0,0,8"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Text="Tip: leave empty to use the ANTHROPIC_API_KEY environment variable."
                                                TextWrapping="Wrap"
                                                Visibility="Collapsed" />
                                            <Button
                                                x:Name="ClaudeAiLoginButton"
                                                Padding="10,7"
                                                Click="ClaudeAiLoginButton_Click"
                                                Content="Login with Claude.ai"
                                                IsEnabled="False"
                                                Visibility="Collapsed" />
                                            <!--  Install button for Codex CLI (Ollama install is now inside OllamaModelPicker)  -->
                                            <Button
                                                x:Name="InstallOllamaButton"
                                                Margin="0,8,0,0"
                                                Padding="10,7"
                                                Click="InstallOllamaButton_Click"
                                                Content="Install Codex CLI"
                                                IsEnabled="False"
                                                Visibility="Collapsed" />
                                            <ProgressBar
                                                x:Name="CodexInstallProgressBar"
                                                Height="4"
                                                Margin="0,8,0,0"
                                                IsIndeterminate="True"
                                                Visibility="Collapsed" />
                                            <TextBlock
                                                x:Name="CodexInstallStatusText"
                                                Margin="0,6,0,0"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                TextWrapping="Wrap"
                                                Visibility="Collapsed" />
                                        </StackPanel>

                                        <TextBlock
                                            x:Name="BaseUrlLabel"
                                            Grid.Row="11"
                                            Margin="0,0,0,4"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="Base URL (optional)" />
                                        <TextBox
                                            x:Name="BaseUrlTextBox"
                                            Grid.Row="12"
                                            Margin="0,0,0,12"
                                            IsEnabled="False"
                                            LostFocus="AutoSave" />

                                        <TextBlock
                                            x:Name="TimeoutLabel"
                                            Grid.Row="13"
                                            Margin="0,0,0,4"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            Text="Request timeout" />
                                        <StackPanel Grid.Row="14" Margin="0,0,0,10">
                                            <Slider
                                                x:Name="TimeoutSlider"
                                                LargeChange="0.05"
                                                Maximum="1"
                                                Minimum="0"
                                                SmallChange="0.01"
                                                ValueChanged="TimeoutSlider_ValueChanged">
                                                <Slider.Template>
                                                    <ControlTemplate TargetType="Slider">
                                                        <Grid Height="24">
                                                            <Border
                                                                Height="8"
                                                                VerticalAlignment="Center"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Offset="0" Color="#2D2D2D" />
                                                                        <GradientStop Offset="0.35" Color="#5B5B5B" />
                                                                        <GradientStop Offset="0.7" Color="#969696" />
                                                                        <GradientStop Offset="1" Color="#C8C8C8" />
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                            </Border>
                                                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                                                <Track.DecreaseRepeatButton>
                                                                    <RepeatButton Command="Slider.DecreaseLarge">
                                                                        <RepeatButton.Template>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border Background="Transparent" />
                                                                            </ControlTemplate>
                                                                        </RepeatButton.Template>
                                                                    </RepeatButton>
                                                                </Track.DecreaseRepeatButton>
                                                                <Track.Thumb>
                                                                    <Thumb>
                                                                        <Thumb.Template>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Ellipse
                                                                                    Width="16"
                                                                                    Height="16"
                                                                                    Fill="{DynamicResource TextBrush}"
                                                                                    Stroke="{DynamicResource BackgroundBrush}"
                                                                                    StrokeThickness="2" />
                                                                            </ControlTemplate>
                                                                        </Thumb.Template>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                                <Track.IncreaseRepeatButton>
                                                                    <RepeatButton Command="Slider.IncreaseLarge">
                                                                        <RepeatButton.Template>
                                                                            <ControlTemplate TargetType="RepeatButton">
                                                                                <Border Background="Transparent" />
                                                                            </ControlTemplate>
                                                                        </RepeatButton.Template>
                                                                    </RepeatButton>
                                                                </Track.IncreaseRepeatButton>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Slider.Template>
                                            </Slider>
                                            <TextBlock
                                                x:Name="TimeoutValueLabel"
                                                Margin="0,4,0,0"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Text="5 minutes" />
                                        </StackPanel>

                                        <CheckBox
                                            x:Name="EnabledCheckBox"
                                            Grid.Row="15"
                                            Checked="AutoSave"
                                            Content="Enabled"
                                            IsEnabled="False"
                                            Unchecked="AutoSave" />

                                        <!--  Row 12: separator  -->
                                        <Separator Grid.Row="16" Margin="0,14,0,10" />

                                        <!--  Row 13: Run Tests header + button  -->
                                        <Grid Grid.Row="17" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextBrush}"
                                                    Text="Capability Tests" />
                                                <TextBlock
                                                    x:Name="CapTestStatusText"
                                                    Margin="0,2,0,0"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    Text="Not yet tested" />
                                            </StackPanel>
                                            <Button
                                                x:Name="StopTestsButton"
                                                Grid.Column="2"
                                                Padding="10,6"
                                                Click="StopTestsButton_Click"
                                                Content="Stop"
                                                Visibility="Collapsed" />
                                            <Button
                                                x:Name="RunTestsButton"
                                                Grid.Column="1"
                                                Padding="10,6"
                                                Click="RunTestsButton_Click"
                                                Content="Run Tests"
                                                IsEnabled="False" />
                                        </Grid>

                                        <!--  Row 14: progress while tests are running  -->
                                        <Border
                                            x:Name="CapTestProgressBorder"
                                            Grid.Row="18"
                                            Margin="0,0,0,8"
                                            Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock
                                                    x:Name="CapTestProgressText"
                                                    Margin="0,0,0,5"
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextSecondaryBrush}"
                                                    Text="Starting tests…" />
                                                <ProgressBar
                                                    x:Name="CapTestProgressBar"
                                                    Height="4"
                                                    Maximum="8"
                                                    Minimum="0"
                                                    Value="0" />
                                            </StackPanel>
                                        </Border>

                                        <!--  Row 15: results panel  -->
                                        <Border
                                            x:Name="CapTestResultsBorder"
                                            Grid.Row="19"
                                            Padding="10,8"
                                            Background="{DynamicResource Surface2Brush}"
                                            CornerRadius="6"
                                            Grid.IsSharedSizeScope="True"
                                            Visibility="Collapsed">
                                            <ScrollViewer
                                                HorizontalScrollBarVisibility="Auto"
                                                VerticalScrollBarVisibility="Disabled">
                                                <StackPanel x:Name="CapTestResultsPanel" MinWidth="650" />
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!--  ══ Appearance tab ══  -->
                <TabItem x:Name="TabAppearance" Header="Appearance">
                    <settingsControls:AppearanceSettingsControl x:Name="AppearanceSettingsControl" />
                </TabItem>

                <!--  ══ Voice tab ══  -->
                <TabItem x:Name="TabVoice" Header="Voice">
                    <settingsControls:VoiceSettingsPaneControl x:Name="VoiceSettingsPaneControl" />
                </TabItem>

                <!--  ══ Context tab ══  -->
                <TabItem x:Name="TabContext" Header="Context">
                    <settingsControls:ContextSettingsPaneControl x:Name="ContextSettingsPaneControl" />
                </TabItem>

                <!--  ══ Auto‑accept tab ══  -->
                <TabItem x:Name="TabAutoAccept" Header="Auto‑accept">
                    <settingsControls:AutoAcceptPaneControl x:Name="AutoAcceptPaneControl" />
                </TabItem>

                <!--  ══ Connections tab ══  -->
                <TabItem x:Name="TabConnections" Header="Connections">
                    <ScrollViewer
                        Margin="0,8,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,8,4,16">

                            <settingsControls:LocalApiAccessPaneControl x:Name="LocalApiAccessPaneControl" />

                            <settingsControls:EmailConnectionsPaneControl x:Name="EmailConnectionsPaneControl" Visibility="Collapsed" />

                            <!--  Separator  -->
                            <Separator
                                Height="1"
                                Margin="0,16,0,16"
                                Background="{DynamicResource BorderBrush}" />

                            <settingsControls:McpConnectionsPaneControl x:Name="McpConnectionsPaneControl" />

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!--  ══ Usage tab ══  -->
                <TabItem x:Name="TabUsage" Header="Usage">
                    <ScrollViewer Margin="0,8,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4,8,4,16">
                            <Border Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14,12"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="UsageOverviewTitleText"
                                               Text="Usage overview"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Margin="0,0,0,10" />
                                    <UniformGrid Columns="2" Rows="2">
                                        <StackPanel Margin="0,0,16,12">
                                            <TextBlock x:Name="UsageRecordedTokensLabel"
                                                       Text="Recorded tokens"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock x:Name="UsageTotalTokensText"
                                                       Text="0"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock x:Name="UsageConversationCountLabel"
                                                       Text="Conversations with usage"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock x:Name="UsageConversationCountText"
                                                       Text="0"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock x:Name="UsageProviderCountLabel"
                                                       Text="Providers with usage"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock x:Name="UsageProviderCountText"
                                                       Text="0"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="UsageAssistantTurnsLabel"
                                                       Text="Assistant turns tracked"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock x:Name="UsageAssistantMessageCountText"
                                                       Text="0"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock x:Name="UsageOverviewHintText"
                                               Text="Tokens are recorded from assistant turns that return usage data. Some providers also expose live quota or spend separately."
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14,12"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock x:Name="UsageTrustTitleText"
                                               Text="What Aire tracks"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Margin="0,0,0,10" />
                                    <UniformGrid Columns="3">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock x:Name="UsageRecordedSourceTitleText"
                                                       Text="Recorded"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock x:Name="UsageRecordedSourceText"
                                                       Text="Stored assistant turns with token counts."
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock x:Name="UsageLiveSourceTitleText"
                                                       Text="Live-reported"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock x:Name="UsageLiveSourceText"
                                                       Text="Provider-reported quota or balance when the API exposes it."
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="UsageEstimatedSourceTitleText"
                                                       Text="Estimated"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" />
                                            <TextBlock x:Name="UsageEstimatedSourceText"
                                                       Text="Not inferred automatically yet; Aire does not guess billing from model names."
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14,12"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="UsageLiveTitleText"
                                                       Text="Live provider usage"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                            <TextBlock x:Name="UsageLiveProviderText"
                                                       Text="No provider selected"
                                                       Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <Button x:Name="UsageRefreshButton"
                                                    Width="34"
                                                    Height="34"
                                                    Padding="0"
                                                    FontSize="16"
                                                    Click="UsageRefreshButton_Click"
                                                    ToolTip="Refresh usage data" />
                                            <Button x:Name="UsageCurrencyButton"
                                                    Width="34"
                                                    Height="34"
                                                    Margin="0,6,0,0"
                                                    Padding="0"
                                                    FontSize="14"
                                                    Click="UsageCurrencyButton_Click"
                                                    ToolTip="Preferred currency" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock x:Name="UsageLiveUsageText"
                                               Text="Open Aire from the main window to see live quota or spend for the active provider."
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock x:Name="UsageLiveUsageDetailText"
                                               Text="If the provider exposes live usage, Aire will show it here. Otherwise the historical totals below still track stored assistant turns."
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource Surface2Brush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14,12"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="UsageTrendTitleText"
                                                       Text="Recorded usage trend"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                            <TextBlock x:Name="UsageTrendHintText"
                                                       Text="Line-spline chart of stored assistant tokens by provider and model."
                                                       Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                    <Border x:Name="UsageTrendChartHost"
                                            Height="220"
                                            Background="{DynamicResource SurfaceBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,0,0,10"
                                            SizeChanged="UsageTrendChartHost_SizeChanged">
                                        <Grid>
                                            <Canvas x:Name="UsageTrendCanvas"
                                                    Background="Transparent" />
                                            <TextBlock x:Name="UsageTrendEmptyText"
                                                       Text="No recorded assistant tokens yet."
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                    </Border>
                                    <ItemsControl x:Name="UsageTrendLegendItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="0,0,12,8"
                                                            VerticalAlignment="Center">
                                                    <Border Width="10"
                                                            Height="10"
                                                            CornerRadius="2"
                                                            Background="{Binding ColorBrush}"
                                                            Margin="0,3,6,0" />
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding TokensText}"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   FontSize="10" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="By provider"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Margin="0,0,0,8" />
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="0">
                                <ListView x:Name="UsageProvidersListView"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsHitTestVisible="False"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="12,10" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="8"
                                                        CornerRadius="4"
                                                        Margin="0,2,10,2"
                                                        Background="{Binding Color}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding ProviderName}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding ProviderDetail}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding TokensText}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontFamily="Consolas, Courier New"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding SpendText}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontFamily="Consolas, Courier New"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding UsageDetailText}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"
                                                               FontFamily="Consolas, Courier New"
                                                               HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>

                            <TextBlock Text="By conversation"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Margin="0,16,0,8" />
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="0">
                                <ListView x:Name="UsageConversationsListView"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsHitTestVisible="False"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="12,10" />
                                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0"
                                                        Width="8"
                                                        CornerRadius="4"
                                                        Margin="0,2,10,2"
                                                        Background="{Binding Color}" />
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding ConversationDetail}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding TokensText}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontFamily="Consolas, Courier New"
                                                               HorizontalAlignment="Right" />
                                                    <TextBlock Text="{Binding SpendText}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontFamily="Consolas, Courier New"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,2,0,0" />
                                                    <TextBlock Text="{Binding UsageDetailText}"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="11"
                                                               Margin="0,2,0,0"
                                                               FontFamily="Consolas, Courier New"
                                                               HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

            <!--  ── Toast notification overlay ──  -->
            <Border
                x:Name="ToastBorder"
                Grid.RowSpan="2"
                Margin="16,0,16,14"
                Padding="12,10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Panel.ZIndex="100"
                CornerRadius="6"
                Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.35"
                        ShadowDepth="2"
                        Color="Black" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="ToastText"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        IsReadOnly="True"
                        IsReadOnlyCaretVisible="True"
                        Focusable="True"
                        Foreground="{DynamicResource TextBrush}"
                        TextWrapping="Wrap" />
                    <Button
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Padding="4,2"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="ToastDismiss_Click"
                        Content="&#x2715;"
                        FontSize="11"
                        Foreground="{DynamicResource TextSecondaryBrush}" />
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
