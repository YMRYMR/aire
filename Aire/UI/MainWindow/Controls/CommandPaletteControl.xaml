<UserControl x:Class="Aire.UI.MainWindow.Controls.CommandPaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Focusable="True">
    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBox x:Name="PART_SearchBox"
                     Grid.Row="0"
                     Background="Transparent"
                     Foreground="{DynamicResource TextBrush}"
                     BorderThickness="0"
                     FontSize="14"
                     Padding="14 10"
                     CaretBrush="{DynamicResource TextBrush}"
                     TextChanged="SearchBox_TextChanged" />

            <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0 0 0 1" />

            <ListBox x:Name="PART_CommandList"
                     Grid.Row="1"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource TextBrush}"
                     MaxHeight="260"
                     SelectionMode="Single"
                     PreviewKeyDown="CommandList_PreviewKeyDown"
                     PreviewMouseLeftButtonDown="CommandList_Click">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8 6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Name}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Shortcut}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="12 0 0 0" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="4 2" CornerRadius="4" SnapsToDevicePixels="True">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface2Brush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface2Brush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
