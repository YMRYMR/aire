<UserControl x:Class="Aire.UI.MainWindow.Controls.MainHeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Background="{DynamicResource AccentSurfaceBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="0 0 0 1"
            Padding="12 10"
            MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button x:Name="PART_SidebarToggleButton"
                    Grid.Column="0"
                    Content="&#x2630;"
                    ToolTip="Conversation history"
                    Width="34"
                    Height="34"
                    Padding="0"
                    Margin="0 0 4 0"
                    Click="SidebarToggleButton_Click" />
            <Button x:Name="PART_HelpButton"
                    Grid.Column="1"
                    Content="&#x003F;"
                    ToolTip="Help"
                    Width="34"
                    Height="34"
                    Padding="0"
                    Margin="0 0 4 0"
                    Click="HelpButton_Click" />
            <Button x:Name="PART_SettingsButton"
                    Grid.Column="2"
                    Content="&#x2699;"
                    ToolTip="Settings"
                    Width="34"
                    Height="34"
                    Padding="0"
                    Margin="0 0 8 0"
                    Click="SettingsButton_Click" />
            <ComboBox x:Name="PART_ProviderComboBox"
                      Grid.Column="3"
                      Margin="0"
                      Foreground="{DynamicResource TextBrush}"
                      SelectionChanged="ProviderComboBox_SelectionChanged"
                      DropDownOpened="ProviderComboBox_DropDownOpened">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="ProviderWarningIcon"
                                       Text="⚠ "
                                       Foreground="{DynamicResource TextBrush}"
                                       Visibility="Collapsed"
                                       ToolTip="Provider is on cooldown"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button x:Name="PART_CheckAgainButton"
                    Grid.Column="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Content="⚠ ↻"
                    ToolTip="Check if provider is available again"
                    Height="22"
                    Padding="6 0"
                    Margin="0 0 4 0"
                    FontSize="12"
                    Foreground="#FFBB00"
                    Visibility="Collapsed"
                    Click="CheckAgainButton_Click" />
            <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8 0 0 0">
                <Button x:Name="PART_ModeButton"
                        Content="General"
                        ToolTip="Assistant mode"
                        Height="34"
                        Padding="10 0"
                        Margin="0 0 4 0"
                        Click="ModeButton_Click" />
                <Button x:Name="PART_SearchButton"
                        Content="&#x1F50D;"
                        ToolTip="Find in chat  (Ctrl+F)"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Margin="0 0 4 0"
                        Click="SearchButton_Click" />
                <Button x:Name="PART_PinButton"
                        Content="&#x1F4CC;"
                        ToolTip="Pin to tray — click to snap window above system tray"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Margin="0 0 4 0"
                        Click="PinButton_Click" />
                <Button x:Name="PART_VoiceOutputButton"
                        Content="&#x1F507;"
                        ToolTip="Voice output off — click to enable"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Margin="0 0 4 0"
                        Click="VoiceOutputButton_Click" />
                <Button x:Name="PART_BrowserButton"
                        Content="&#x1F310;"
                        ToolTip="Open browser  (AI can read open tabs)"
                        Width="34"
                        Height="34"
                        Padding="0"
                        Margin="0"
                        Click="BrowserButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
