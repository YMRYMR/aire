<UserControl x:Class="Aire.UI.MainWindow.Controls.MessageListItemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:Aire.UI">
    <UserControl.Resources>
        <ui:PercentageConverter x:Key="PercentageConverter" />
    </UserControl.Resources>
    <Grid Margin="0 3">
        <Border x:Name="DateSeparator"
                Visibility="Collapsed"
                Margin="0 8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="{DynamicResource Surface2Brush}"
                        CornerRadius="10"
                        Padding="14 4">
                    <TextBlock Text="{Binding Text}"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Border>
            </StackPanel>
        </Border>
        <TextBox x:Name="SystemText"
                 Text="{Binding Text, Mode=OneWay}"
                 Foreground="{Binding SenderForeground}"
                 FontSize="11"
                 HorizontalAlignment="Center"
                 TextWrapping="Wrap"
                 Margin="20 2"
                 Visibility="Collapsed"
                 IsReadOnly="True"
                 BorderThickness="0"
                 Background="Transparent"
                 Padding="0"
                 VerticalContentAlignment="Center"
                 HorizontalContentAlignment="Center"
                 Focusable="True"
                 Cursor="IBeam"
                 IsReadOnlyCaretVisible="False"
                 VerticalScrollBarVisibility="Disabled"
                 HorizontalScrollBarVisibility="Disabled" />
        <StackPanel x:Name="MessageRow"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left">
            <Border x:Name="MessageBorder"
                    CornerRadius="14 14 14 4"
                    Padding="12 8"
                    Background="{DynamicResource AssistantMessageBrush}"
                    MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualWidth, Converter={StaticResource PercentageConverter}, ConverterParameter=0.7}">
                <StackPanel>
                    <ItemsControl x:Name="InlineImagesPanel"
                                  ItemsSource="{Binding InlineImages}"
                                  Visibility="Collapsed"
                                  Margin="0 0 0 6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Image Source="{Binding}"
                                       MaxWidth="280"
                                       MaxHeight="220"
                                       Stretch="Uniform"
                                       Margin="0 0 0 6"
                                       HorizontalAlignment="Left"
                                       Cursor="Hand"
                                       ToolTip="Click to open in image viewer"
                                       MouseLeftButtonUp="InlineImage_MouseLeftButtonUp" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Image x:Name="AttachedImageElement"
                           Source="{Binding AttachedImage, Mode=OneWay}"
                           Visibility="Collapsed"
                           MaxWidth="280"
                           MaxHeight="200"
                           Stretch="Uniform"
                           Margin="0 0 0 6"
                           HorizontalAlignment="Left"
                           Cursor="Hand"
                           ToolTip="Click to open in image viewer"
                           MouseLeftButtonUp="AttachedImageElement_MouseLeftButtonUp" />
                    <ItemsControl x:Name="FileAttachmentsPanel"
                                  ItemsSource="{Binding FileAttachments}"
                                  Visibility="Collapsed"
                                  Margin="0 0 0 6">
                        <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding DisplayLabel}"
                                        Margin="0 0 0 6"
                                        Padding="10 4"
                                        HorizontalAlignment="Left"
                                        Focusable="True"
                                        AutomationProperties.Name="{Binding DisplayLabel}"
                                        AutomationProperties.HelpText="Open attached file"
                                        ToolTip="{Binding FilePath}"
                                        Click="FileAttachmentButton_Click" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    <RichTextBox x:Name="MessageText"
                                 ui:LinkedText.Text="{Binding Text}"
                                 Foreground="{DynamicResource AssistantMessageTextBrush}"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="False"
                                 IsDocumentEnabled="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 SelectionBrush="{DynamicResource PrimaryHoverBrush}"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 IsTabStop="False"
                                 Cursor="IBeam"
                                 FocusVisualStyle="{x:Null}" />
                    <TextBox x:Name="ToolCallDescriptionText"
                             Text="{Binding PendingToolCall.Description, Mode=OneWay}"
                             Visibility="Collapsed"
                             Foreground="{DynamicResource TextBrush}"
                             FontSize="12"
                             TextWrapping="Wrap"
                             Margin="0 4 0 0"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             VerticalContentAlignment="Top"
                             Focusable="True"
                             Cursor="IBeam"
                             IsReadOnlyCaretVisible="False"
                             VerticalScrollBarVisibility="Hidden"
                             HorizontalScrollBarVisibility="Disabled" />
                    <TextBox x:Name="ToolCallStatusText"
                             Text="{Binding ToolCallStatus, Mode=OneWay}"
                             Visibility="Collapsed"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             FontSize="11"
                             TextWrapping="Wrap"
                             Margin="0 4 0 0"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             VerticalContentAlignment="Top"
                             Focusable="True"
                             Cursor="IBeam"
                             IsReadOnlyCaretVisible="False"
                             VerticalScrollBarVisibility="Hidden"
                             HorizontalScrollBarVisibility="Disabled" />
                    <Border x:Name="TodoListPanel"
                            Visibility="Collapsed"
                            Margin="0 6 0 0">
                        <ItemsControl ItemsSource="{Binding TodoItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0 3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding StatusIcon}"
                                                   Foreground="{Binding StatusColor}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Top"
                                                   Margin="0 1 0 0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            <Setter Property="Opacity" Value="0.55" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <Border x:Name="FollowUpPanel"
                            Visibility="Collapsed"
                            Margin="0 6 0 0">
                        <StackPanel>
                            <TextBlock Text="{Binding FollowUpQuestion}"
                                       TextWrapping="Wrap"
                                       FontWeight="SemiBold"
                                       Margin="0 0 0 8" />
                            <ItemsControl x:Name="AnswerButtonsPanel"
                                          ItemsSource="{Binding FollowUpOptions}"
                                          Visibility="Collapsed">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}"
                                                Margin="0 0 6 6"
                                                Click="AnswerButton_Click" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Image x:Name="ScreenshotImageElement"
                           Source="{Binding ScreenshotImage, Mode=OneWay}"
                           Visibility="Collapsed"
                           MaxWidth="400"
                           MaxHeight="300"
                           Stretch="Uniform"
                           Margin="0 6 0 0"
                           HorizontalAlignment="Left"
                           Cursor="Hand"
                           ToolTip="Click to open in image viewer"
                           MouseLeftButtonUp="ScreenshotImageElement_MouseLeftButtonUp" />
                    <TextBlock Text="{Binding Timestamp}"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Right"
                               Margin="0 3 0 0" />
                </StackPanel>
            </Border>
            <StackPanel x:Name="ToolApprovalPanel"
                        Visibility="Collapsed"
                        VerticalAlignment="Center"
                        Margin="6 0 0 0">
                <Button x:Name="ApproveToolButton"
                        Content="&#x2713;"
                        ToolTip="Allow"
                        Tag="{Binding}"
                        Click="ApproveToolButton_Click"
                        Width="34"
                        Height="34"
                        Margin="0 0 0 4" />
                <Button x:Name="DenyToolButton"
                        Content="&#x2717;"
                        ToolTip="Deny"
                        Tag="{Binding}"
                        Click="DenyToolButton_Click"
                        Width="34"
                        Height="34" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
