<UserControl x:Class="Aire.UI.MainWindow.Controls.MainComposerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:Aire.UI"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ui:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="OrchestratorModeButtonStyle"
               TargetType="ToggleButton"
               BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontFamily" Value="Segoe UI Symbol, Segoe UI Emoji, Segoe UI" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryPressedBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D73A49" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8B1F2B" />
                                <Setter Property="Foreground" Value="White" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="OrchestratorHeartbeatStoryboard">
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.08"
                                                             Duration="0:0:0.45" />
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.08"
                                                             Duration="0:0:0.45" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="OrchestratorHeartbeatStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0 1 0 0"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Orchestrator mode status banner -->
            <Border x:Name="PART_AgentModeBanner"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    Background="{DynamicResource AccentSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="0 0 0 1"
                    CornerRadius="6"
                    Padding="10 6"
                    Margin="0 0 0 8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="⚙"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0 0 8 0" />
                    <TextBlock x:Name="PART_AgentModeStatusText"
                               Grid.Column="1"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Text="Orchestrator active" />
                    <Button x:Name="PART_StopAgentButton"
                            Grid.Column="2"
                            Content="Stop"
                            Click="StopAgentButton_Click"
                            Height="26"
                            Padding="10 0"
                            FontSize="11" />
                </Grid>
            </Border>

            <Border x:Name="PART_MouseSessionBanner"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    Background="{DynamicResource Surface2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0 0 0 1"
                    CornerRadius="6"
                    Padding="10 6"
                    Margin="0 0 0 8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PART_MouseSessionLabel"
                               Grid.Column="0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Text="Session active" />
                    <Button x:Name="PART_EndSessionButton"
                            Grid.Column="1"
                            Content="End session"
                            Click="EndSessionButton_Click"
                            Height="26"
                            Padding="10 0"
                            FontSize="11" />
                </Grid>
            </Border>

            <StackPanel x:Name="PART_ImagePreviewPanel"
                        Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0 0 0 8"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                <Border x:Name="PART_ImageThumbnailBorder"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="4"
                        Margin="0 0 8 0"
                        Visibility="Collapsed">
                    <Image x:Name="PART_AttachedImagePreview" Width="48" Height="48" Stretch="UniformToFill" />
                </Border>

                <Border x:Name="PART_FileChipBorder"
                        Background="{DynamicResource Surface2Brush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8 6"
                        Margin="0 0 8 0"
                        Cursor="Hand"
                        Visibility="Collapsed"
                        MouseLeftButtonUp="FileChipBorder_MouseLeftButtonUp"
                        ToolTip="Click to open file">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📄" FontSize="18" VerticalAlignment="Center" Margin="0 0 6 0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="PART_AttachedFileNameText"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       MaxWidth="180"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="PART_AttachedFileSizeText"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="PART_LargeFileWarning"
                        Background="{DynamicResource WarningBackgroundBrush}"
                        BorderBrush="{DynamicResource WarningBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="6 4"
                        Margin="0 0 8 0"
                        Visibility="Collapsed"
                        VerticalAlignment="Center">
                    <TextBlock Text="⚠ Large file — provider may reject"
                               Foreground="{DynamicResource WarningBrush}"
                               FontSize="11" />
                </Border>

                <Button x:Name="PART_RemoveImageButton"
                        Content="×"
                        ToolTip="Remove attachment"
                        Width="28"
                        Height="28"
                        Padding="0"
                        VerticalAlignment="Center"
                        Click="RemoveImageButton_Click" />
            </StackPanel>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PART_StopAiButton"
                        Grid.Column="0"
                        Content="⏹️"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Margin="0 0 6 0"
                        Click="StopAiButton_Click"
                        Visibility="{Binding IsThinking, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBox x:Name="PART_InputTextBox"
                         Grid.Column="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         MinHeight="40"
                         MaxHeight="120"
                         Padding="10 8"
                         PreviewKeyDown="InputTextBox_KeyDown"
                         AllowDrop="True"
                         PreviewDrop="InputTextBox_Drop"
                         PreviewDragOver="InputTextBox_DragOver" />
                <Button x:Name="PART_MicButton"
                        Grid.Column="2"
                        Content="&#x1F3A4;"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Margin="6 0 0 0"
                        FontSize="13"
                        Click="MicButton_Click" />
                <Button x:Name="PART_ToolsButton"
                        Grid.Column="3"
                        Content="&#x1F527;"
                        Width="40"
                        Height="40"
                        Padding="0"
                        Margin="6 0 0 0"
                        FontSize="13"
                        Click="ToolsButton_Click" />
                <ToggleButton x:Name="PART_AgentModeButton"
                              Grid.Column="4"
                              Content="⦿"
                              Width="40"
                              Height="40"
                              Margin="6 0 0 0"
                              Padding="0"
                              Style="{StaticResource OrchestratorModeButtonStyle}"
                              Click="AgentModeButton_Click" />

                <Border x:Name="PART_ProgressOverlay"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        Background="{DynamicResource AccentSurfaceBrush}"
                        BorderBrush="{DynamicResource AccentBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Opacity="0.96"
                        Visibility="Collapsed"
                        Panel.ZIndex="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Foreground="{DynamicResource PrimaryHoverBrush}"
                                     Width="200"
                                     Height="4"
                                     Margin="0 0 0 10" />
                        <TextBlock x:Name="PART_ThinkingText"
                                   Text="Thinking&#x2026;"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
