<Window x:Class="Aire.UI.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Image Viewer"
        Width="860" Height="640"
        MinWidth="360" MinHeight="260"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="4" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── Title bar ─────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource AccentSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Image Viewer"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="&#x2715;"
                            ToolTip="Close (Esc)"
                            Width="34" Height="34"
                            Padding="0"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>

            <!-- ── Toolbar ───────────────────────────────────────────── -->
            <Border Grid.Row="1"
                    Background="{DynamicResource Surface2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,5">
                <DockPanel LastChildFill="False">
                    <!-- Zoom label (left) -->
                    <TextBlock x:Name="ZoomLabel"
                               DockPanel.Dock="Left"
                               Text="100%"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Width="46" />

                    <!-- Buttons (right) -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Button Content="&#x2212;"
                                ToolTip="Zoom out (–)"
                                Width="30" Height="26"
                                Padding="0"
                                Margin="0,0,4,0"
                                Click="ZoomOutButton_Click" />
                        <Button Content="&#x2b;"
                                ToolTip="Zoom in (+)"
                                Width="30" Height="26"
                                Padding="0"
                                Margin="0,0,8,0"
                                Click="ZoomInButton_Click" />
                        <Button Content="Fit"
                                ToolTip="Fit to window (F)"
                                Width="36" Height="26"
                                Padding="4,0"
                                Margin="0,0,4,0"
                                Click="FitButton_Click" />
                        <Button Content="1:1"
                                ToolTip="Actual pixel size"
                                Width="36" Height="26"
                                Padding="4,0"
                                Margin="0,0,12,0"
                                Click="ActualSizeButton_Click" />
                        <Button Content="Copy"
                                ToolTip="Copy to clipboard (Ctrl+C)"
                                Height="26"
                                Padding="10,0"
                                Margin="0,0,4,0"
                                Click="CopyButton_Click" />
                        <Button Content="Save As…"
                                ToolTip="Save image (Ctrl+S)"
                                Height="26"
                                Padding="10,0"
                                Click="SaveButton_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Viewport ──────────────────────────────────────────── -->
            <Border x:Name="ViewportBorder"
                    Grid.Row="2"
                    Background="#0D0E12"
                    ClipToBounds="True"
                    Focusable="True"
                    Cursor="Arrow"
                    MouseWheel="Viewport_MouseWheel"
                    MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                    MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                    MouseMove="Viewport_MouseMove"
                    MouseRightButtonUp="Viewport_MouseRightButtonUp"
                    SizeChanged="Viewport_SizeChanged">
                <!-- Canvas gives the Image its full desired size during arrange,
                     preventing the WPF layout clip that would otherwise crop the
                     bitmap to the Border's size before the RenderTransform runs. -->
                <Canvas>
                    <Image x:Name="ViewerImage"
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Canvas>
            </Border>
        </Grid>
    </Border>
</Window>
