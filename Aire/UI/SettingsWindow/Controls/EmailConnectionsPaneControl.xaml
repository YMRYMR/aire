<UserControl x:Class="Aire.UI.Settings.Controls.EmailConnectionsPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock x:Name="PART_EmailAccountsTitle"
                   Text="Email Accounts"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0 0 0 4"/>
        <TextBlock x:Name="PART_EmailAccountsDescription"
                   TextWrapping="Wrap"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0 0 0 8"
                   Text="Connect your email so the AI can read and send emails on your behalf."/>

        <WrapPanel Margin="0 0 0 8">
            <Button x:Name="PART_AddGmailBtn" Content="+ Gmail" Height="26" Padding="10 0" Margin="0 0 6 0" Click="AddGmailBtn_Click"/>
            <Button x:Name="PART_AddOutlookBtn" Content="+ Outlook" Height="26" Padding="10 0" Margin="0 0 6 0" Click="AddOutlookBtn_Click"/>
            <Button x:Name="PART_AddCustomEmailBtn" Content="+ Custom…" Height="26" Padding="10 0" Click="AddCustomEmailBtn_Click"/>
        </WrapPanel>

        <ListView x:Name="PART_EmailAccountsList" MaxHeight="140" Margin="0 0 0 4" SelectionChanged="EmailAccountsList_SelectionChanged" FontSize="11">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Account" Width="160" DisplayMemberBinding="{Binding DisplayName}"/>
                    <GridViewColumn Header="Provider" Width="76" DisplayMemberBinding="{Binding ProviderText}"/>
                    <GridViewColumn Header="Status" Width="52">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Ellipse Width="9" Height="9" Fill="{Binding StatusColor}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="" Width="114">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Test" Width="48" Height="20" FontSize="11" Margin="0 0 4 0" Tag="{Binding}" Click="TestEmailBtn_Click"/>
                                    <Button Content="Delete" Width="52" Height="20" FontSize="11" Tag="{Binding}" Click="DeleteEmailBtn_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Border x:Name="PART_EmailEditPanel" Visibility="Collapsed"
                Background="{DynamicResource Surface2Brush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="12 10" Margin="0 0 0 4">
            <StackPanel>
                <TextBlock x:Name="PART_EmailEditTitle" Text="Add email account" FontWeight="SemiBold" FontSize="11"
                           Foreground="{DynamicResource TextBrush}" Margin="0 0 0 10"/>

                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Display name" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                        <TextBox x:Name="PART_EmailDisplayNameBox"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Provider" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                        <ComboBox x:Name="PART_EmailProviderCombo" SelectionChanged="EmailProviderCombo_SelectionChanged">
                            <ComboBoxItem Content="Gmail" Tag="Gmail"/>
                            <ComboBoxItem Content="Outlook" Tag="Outlook"/>
                            <ComboBoxItem Content="Custom…" Tag="Custom"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel x:Name="PART_EmailHostsPanel">
                    <TextBlock Text="IMAP host" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PART_EmailImapHostBox" Grid.Column="0"/>
                        <TextBox x:Name="PART_EmailImapPortBox" Grid.Column="2"/>
                    </Grid>
                    <TextBlock Text="SMTP host" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="PART_EmailSmtpHostBox" Grid.Column="0"/>
                        <TextBox x:Name="PART_EmailSmtpPortBox" Grid.Column="2"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="Email address" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                <TextBox x:Name="PART_EmailUsernameBox" Margin="0 0 0 8"/>

                <StackPanel x:Name="PART_EmailPasswordPanel">
                    <TextBlock Text="Password" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0 0 0 4"/>
                    <PasswordBox x:Name="PART_EmailPasswordBox" Margin="0 0 0 8"/>
                    <TextBlock Text="Outlook: use an App Password (Microsoft Account → Security → App passwords)."
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0 0 0 10"/>
                </StackPanel>

                <StackPanel x:Name="PART_EmailOAuthPanel" Visibility="Collapsed" Orientation="Horizontal" Margin="0 0 0 10">
                    <Button x:Name="PART_SignInWithGoogleBtn" Content="Sign in with Google" Height="26" Padding="10 0" FontSize="11" Click="SignInWithGoogleBtn_Click"/>
                    <TextBlock x:Name="PART_OAuthStatusText" VerticalAlignment="Center" Margin="10 0 0 0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PART_SaveEmailBtn" Content="Save" Width="72" Height="26" FontSize="11" Margin="0 0 6 0" Click="SaveEmailBtn_Click"/>
                    <Button x:Name="PART_CancelEmailBtn" Content="Cancel" Width="72" Height="26" FontSize="11" Click="CancelEmailBtn_Click"/>
                    <Button x:Name="PART_TestEmailConnBtn" Content="Test connection" Height="26" FontSize="11" Padding="10 0" Margin="14 0 0 0" Click="TestEmailConnBtn_Click"/>
                    <TextBlock x:Name="PART_EmailTestResult" VerticalAlignment="Center" Margin="8 0 0 0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
