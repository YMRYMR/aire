<UserControl x:Class="Aire.UI.Settings.Controls.AppearanceSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="AppearanceSliderThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{DynamicResource TextBrush}"
                                 Stroke="{DynamicResource BackgroundBrush}"
                                 StrokeThickness="2" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="GradientSliderTemplate" TargetType="Slider">
            <Grid Height="24">
                <Border Height="8"
                        VerticalAlignment="Center"
                        CornerRadius="4"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1" />
                <Track x:Name="PART_Track"
                       VerticalAlignment="Center"
                       IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="Slider.DecreaseLarge"
                                      Opacity="0"
                                      IsTabStop="False" />
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource AppearanceSliderThumbStyle}" />
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="Slider.IncreaseLarge"
                                      Opacity="0"
                                      IsTabStop="False" />
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <LinearGradientBrush x:Key="BrightnessSliderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#191919" Offset="0" />
            <GradientStop Color="#3A3A3A" Offset="0.2" />
            <GradientStop Color="#7A7A7A" Offset="0.5" />
            <GradientStop Color="#BEBEBE" Offset="0.8" />
            <GradientStop Color="#F2F2F2" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TintSliderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#7A7A7A" Offset="0" />
            <GradientStop Color="#D84A4A" Offset="0.16" />
            <GradientStop Color="#E2B23C" Offset="0.32" />
            <GradientStop Color="#59B85D" Offset="0.50" />
            <GradientStop Color="#3BAFC7" Offset="0.68" />
            <GradientStop Color="#6E66D6" Offset="0.84" />
            <GradientStop Color="#7A7A7A" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentBrightnessSliderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1D2430" Offset="0" />
            <GradientStop Color="#4D657E" Offset="0.35" />
            <GradientStop Color="#93A9C0" Offset="0.7" />
            <GradientStop Color="#D9E3EE" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GraySliderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#2D2D2D" Offset="0" />
            <GradientStop Color="#5B5B5B" Offset="0.35" />
            <GradientStop Color="#969696" Offset="0.7" />
            <GradientStop Color="#C8C8C8" Offset="1" />
        </LinearGradientBrush>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0 8 0 0">
        <StackPanel x:Name="PART_AppearanceSection" Margin="8 8 8 16" HorizontalAlignment="Stretch">
            <Grid Margin="0 0 0 2">
                <TextBlock x:Name="PART_BrightnessLabel" Text="Brightness" Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center" />
                <TextBlock x:Name="PART_BrightnessValueLabel" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextBrush}" />
            </Grid>
            <Slider x:Name="PART_BrightnessSlider"
                    Minimum="0"
                    Maximum="1"
                    SmallChange="0.01"
                    LargeChange="0.1"
                    Background="{StaticResource BrightnessSliderBrush}"
                    Template="{StaticResource GradientSliderTemplate}"
                    ValueChanged="BrightnessSlider_ValueChanged" />

            <Grid Margin="0 0 0 2">
                <TextBlock x:Name="PART_ColorTintLabel" Text="Color tint" Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center" />
                <TextBlock x:Name="PART_TintValueLabel" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextBrush}" />
            </Grid>
            <Slider x:Name="PART_TintSlider"
                    Minimum="0"
                    Maximum="1"
                    SmallChange="0.005"
                    LargeChange="0.05"
                    Background="{StaticResource TintSliderBrush}"
                    Template="{StaticResource GradientSliderTemplate}"
                    ValueChanged="TintSlider_ValueChanged" />
            <Grid Margin="0 3 0 20">
                <TextBlock x:Name="PART_NeutralLeftLabel" Text="← Neutral" HorizontalAlignment="Left" FontSize="10" Foreground="{DynamicResource TextBrush}" />
                <TextBlock x:Name="PART_NeutralRightLabel" Text="Neutral →" HorizontalAlignment="Right" FontSize="10" Foreground="{DynamicResource TextBrush}" />
            </Grid>

            <TextBlock x:Name="PART_AccentBrightnessLabel" Text="Accent brightness" Foreground="{DynamicResource TextBrush}" FontSize="11" Margin="0 0 0 6" />
            <Slider x:Name="PART_AccentBrightnessSlider"
                    Minimum="0"
                    Maximum="1"
                    SmallChange="0.01"
                    LargeChange="0.1"
                    Background="{StaticResource AccentBrightnessSliderBrush}"
                    Template="{StaticResource GradientSliderTemplate}"
                    ValueChanged="AccentBrightnessSlider_ValueChanged" />

            <TextBlock x:Name="PART_AccentTintLabel" Text="Accent color" Foreground="{DynamicResource TextBrush}" FontSize="11" Margin="0 12 0 6" />
            <Slider x:Name="PART_AccentTintSlider"
                    Minimum="0"
                    Maximum="1"
                    SmallChange="0.005"
                    LargeChange="0.05"
                    Background="{StaticResource TintSliderBrush}"
                    Template="{StaticResource GradientSliderTemplate}"
                    ValueChanged="AccentTintSlider_ValueChanged" />
            <Grid Margin="0 3 0 20">
                <TextBlock x:Name="PART_AccentNeutralLeftLabel" Text="← Neutral" HorizontalAlignment="Left" FontSize="10" Foreground="{DynamicResource TextBrush}" />
                <TextBlock x:Name="PART_AccentNeutralRightLabel" Text="Neutral →" HorizontalAlignment="Right" FontSize="10" Foreground="{DynamicResource TextBrush}" />
            </Grid>

            <Grid Margin="0 0 0 2">
                <TextBlock x:Name="PART_FontSizeLabel" Text="Font size" Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center" />
                <TextBlock x:Name="PART_FontSizeDisplay" HorizontalAlignment="Right" FontSize="11" Foreground="{DynamicResource TextBrush}" />
            </Grid>
            <Slider x:Name="PART_FontSizeSlider"
                    Minimum="8"
                    Maximum="24"
                    SmallChange="1"
                    LargeChange="2"
                    IsSnapToTickEnabled="True"
                    TickFrequency="1"
                    Margin="0 0 0 4"
                    Background="{StaticResource GraySliderBrush}"
                    Template="{StaticResource GradientSliderTemplate}"
                    ValueChanged="FontSizeSlider_ValueChanged" />

            <TextBlock x:Name="PART_LanguageLabel" Text="Language" Foreground="{DynamicResource TextBrush}" FontSize="11" Margin="0 12 0 6" />
            <ComboBox x:Name="PART_LanguageComboBox" HorizontalAlignment="Stretch" FontFamily="Segoe UI, Segoe UI Emoji" SelectionChanged="LanguageComboBox_SelectionChanged" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
