<UserControl x:Class="Aire.UI.Settings.Controls.McpConnectionsPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Item container for card-style lists — replaces global GridViewRowPresenter with ContentPresenter -->
        <Style x:Key="CardListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Margin"                     Value="0 0 0 6"/>
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="FocusVisualStyle"           Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter HorizontalAlignment="Stretch"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact action button used inside catalog and server cards -->
        <Style x:Key="CardActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize"  Value="11"/>
            <Setter Property="Padding"   Value="10 4"/>
            <Setter Property="Margin"    Value="0"/>
            <Setter Property="MinWidth"  Value="72"/>
        </Style>

        <!-- Even smaller button for inline Edit/Remove in server rows -->
        <Style x:Key="RowActionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize"  Value="11"/>
            <Setter Property="Padding"   Value="8 3"/>
            <Setter Property="Margin"    Value="0"/>
        </Style>
    </UserControl.Resources>

    <StackPanel>

        <!-- ══ Header ══ -->
        <TextBlock x:Name="PART_McpServersTitle"
                   Text="MCP Servers"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0 0 0 4"/>
        <TextBlock x:Name="PART_McpServersDescription"
                   Text="Extend the AI with custom tools by connecting MCP servers. Changes take effect immediately."
                   TextWrapping="Wrap"
                   FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0 0 0 10"/>

        <!-- Node.js info banner -->
        <Border Background="{DynamicResource AccentSurfaceBrush}"
                BorderBrush="{DynamicResource AccentBorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10 7"
                Margin="0 0 0 20">
            <TextBlock x:Name="PART_McpTipText"
                       Text="Most servers require Node.js (npx). If a server fails to start, make sure Node.js is installed — nodejs.org"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>

        <!-- ══ Discover section ══ -->
        <TextBlock x:Name="PART_McpCatalogTitle"
                   Text="Discover"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0 0 0 8"/>

        <!-- Search / filter box with placeholder overlay -->
        <Grid Margin="0 0 0 10">
            <TextBox x:Name="PART_McpSearchBox"
                     Height="28"
                     Padding="8 4"
                     FontSize="11"
                     VerticalContentAlignment="Center"
                     TextChanged="McpSearchBox_TextChanged"/>
            <TextBlock Text="Search servers…"
                       IsHitTestVisible="False"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       VerticalAlignment="Center"
                       Margin="10 0 0 0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=PART_McpSearchBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <ListView x:Name="PART_McpCatalogList"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  Margin="0 0 0 24"
                  FontSize="11"
                  ItemContainerStyle="{StaticResource CardListItemStyle}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="11 9"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: name + chips + description -->
                            <StackPanel Grid.Column="0" Margin="0 0 14 0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center"/>
                                    <!-- Category chip -->
                                    <Border Margin="8 0 0 0"
                                            Padding="6 2"
                                            Background="{DynamicResource Surface3Brush}"
                                            CornerRadius="10"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="10"/>
                                    </Border>
                                    <!-- Installed badge — only shown when installed -->
                                    <Border Margin="6 0 0 0"
                                            Padding="6 2"
                                            Background="{DynamicResource AccentSurfaceBrush}"
                                            BorderBrush="{DynamicResource AccentBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Installed"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="10"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}"
                                           TextWrapping="Wrap"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Right: Install / Remove button (no fixed height — lets it size naturally) -->
                            <Button Grid.Column="1"
                                    Content="{Binding ActionLabel}"
                                    Style="{StaticResource CardActionButtonStyle}"
                                    Tag="{Binding}"
                                    VerticalAlignment="Center"
                                    Click="CatalogMcpActionBtn_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ══ Installed Servers section header ══ -->
        <Grid Margin="0 0 0 8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Installed Servers"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="PART_AddMcpBtn"
                        Content="+ Custom"
                        Style="{StaticResource CardActionButtonStyle}"
                        Margin="0 0 6 0"
                        Click="AddMcpBtn_Click"/>
                <Button x:Name="PART_McpTemplatesBtn"
                        Content="Templates ▾"
                        Style="{StaticResource CardActionButtonStyle}"
                        Click="McpTemplatesBtn_Click">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="PART_McpTemplatesMenu"/>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Installed servers list -->
        <ListView x:Name="PART_McpServersList"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  Margin="0 0 0 4"
                  FontSize="11"
                  ItemContainerStyle="{StaticResource CardListItemStyle}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  SelectionChanged="McpServersList_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="11 8"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Toggle + status dot -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Margin="0 0 12 0"
                                        VerticalAlignment="Center">
                                <CheckBox IsChecked="{Binding IsEnabled}"
                                          VerticalAlignment="Center"
                                          Click="McpEnabledToggle_Click"/>
                                <Ellipse Width="8" Height="8"
                                         Fill="{Binding StatusColor}"
                                         Margin="8 0 0 0"
                                         VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Name + command preview -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="{Binding CommandPreview}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Edit + Remove -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="12 0 0 0">
                                <Button Content="Edit"
                                        Style="{StaticResource RowActionButtonStyle}"
                                        Margin="0 0 5 0"
                                        Tag="{Binding}"
                                        Click="EditMcpBtn_Click"/>
                                <Button Content="Remove"
                                        Style="{StaticResource RowActionButtonStyle}"
                                        Tag="{Binding}"
                                        Click="DeleteMcpBtn_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ══ Edit / Add panel (shown on demand) ══ -->
        <Border x:Name="PART_McpEditPanel"
                Visibility="Collapsed"
                Background="{DynamicResource Surface2Brush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="5"
                Padding="14 12"
                Margin="0 10 0 0">
            <StackPanel>
                <TextBlock x:Name="PART_McpEditTitle"
                           Text="Add custom server"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0 0 0 12"/>

                <TextBlock Text="Name"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0 0 0 3"/>
                <TextBox x:Name="PART_McpNameBox"
                         Height="26"
                         Padding="6 3"
                         VerticalContentAlignment="Center"
                         FontSize="11"
                         Margin="0 0 0 10"/>

                <Grid Margin="0 0 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Command"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0 0 0 3"/>
                        <TextBox x:Name="PART_McpCommandBox"
                                 Height="26"
                                 Padding="6 3"
                                 VerticalContentAlignment="Center"
                                 FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Arguments"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0 0 0 3"/>
                        <TextBox x:Name="PART_McpArgsBox"
                                 Height="26"
                                 Padding="6 3"
                                 VerticalContentAlignment="Center"
                                 FontSize="11"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Working directory (optional)"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0 0 0 3"/>
                <TextBox x:Name="PART_McpWorkDirBox"
                         Height="26"
                         Padding="6 3"
                         VerticalContentAlignment="Center"
                         FontSize="11"
                         Margin="0 0 0 10"/>

                <TextBlock Text="Environment variables — one per line:  KEY=value"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0 0 0 3"/>
                <TextBox x:Name="PART_McpEnvVarsBox"
                         Height="64"
                         Padding="6 4"
                         TextWrapping="Wrap"
                         FontSize="11"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0 0 0 12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="PART_SaveMcpBtn"
                                Content="Save"
                                Width="72"
                                Height="26"
                                FontSize="11"
                                Padding="6 3"
                                Margin="0 0 6 0"
                                Click="SaveMcpBtn_Click"/>
                        <Button x:Name="PART_CancelMcpBtn"
                                Content="Cancel"
                                Width="72"
                                Height="26"
                                FontSize="11"
                                Padding="6 3"
                                Click="CancelMcpBtn_Click"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PART_TestMcpBtn"
                                Content="Test connection"
                                Height="26"
                                FontSize="11"
                                Padding="10 3"
                                Margin="0"
                                Click="TestMcpBtn_Click"/>
                        <TextBlock x:Name="PART_McpTestResult"
                                   VerticalAlignment="Center"
                                   Margin="10 0 0 0"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
