<UserControl x:Class="Aire.UI.Settings.Controls.VoiceSettingsPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0 8 0 0">
        <StackPanel x:Name="PART_VoiceSection"
                    Margin="4 8 4 24"
                    HorizontalAlignment="Stretch"
                    MaxWidth="760">

            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16 14"
                    Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="Voice"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0 0 0 4" />
                    <TextBlock Text="Pick how Aire speaks, then press the sound button to hear it."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16 14"
                    Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock x:Name="PART_VoiceVoiceLabel"
                               Text="Voice"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0 0 0 8" />
                    <Grid Margin="0 0 0 8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="PART_VoiceComboBox"
                                  Grid.Column="0"
                                  MinWidth="280"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="VoiceComboBox_SelectionChanged" />
                        <Button x:Name="PART_TestVoiceButton"
                                Grid.Column="1"
                                Content="&#x1F50A;"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Margin="8 0 0 0"
                                ToolTip="Test selected voice"
                                Click="TestVoiceButton_Click" />
                    </Grid>

                    <Border x:Name="PART_VoiceTestErrorBorder"
                            Visibility="Collapsed"
                            Background="{DynamicResource Surface2Brush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10 8"
                            Margin="0 2 0 0">
                        <TextBlock x:Name="PART_VoiceTestErrorText"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16 14"
                    Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="Voice source"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0 0 0 8" />
                    <CheckBox x:Name="PART_VoiceLocalOnlyCheckBox"
                              Content="Use local voices only"
                              Margin="0 0 0 4"
                              Checked="VoiceLocalOnlyCheckBox_Changed"
                              Unchecked="VoiceLocalOnlyCheckBox_Changed" />
                    <TextBlock Text="Keeps speech offline and avoids downloading or using cloud voices."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="20 2 0 10" />

                    <Button x:Name="PART_DownloadVoicesButton"
                            Content="Download Windows voices..."
                            HorizontalAlignment="Left"
                            Padding="12 7"
                            Click="DownloadVoicesButton_Click" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16 14"
                    Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock x:Name="PART_VoiceSpeedLabel"
                               Text="Speed"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Margin="0 0 0 8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PART_VoiceSpeedDecreaseButton"
                                Grid.Column="0"
                                Content="&#x2212;"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Margin="0 0 6 0"
                                Click="VoiceSpeedDecreaseButton_Click" />
                        <TextBlock x:Name="PART_VoiceSpeedDisplay"
                                   Grid.Column="1"
                                   Width="52"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold" />
                        <Button x:Name="PART_VoiceSpeedIncreaseButton"
                                Grid.Column="2"
                                Content="+"
                                Width="36"
                                Height="36"
                                Padding="0"
                                Margin="6 0 0 0"
                                Click="VoiceSpeedIncreaseButton_Click" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
