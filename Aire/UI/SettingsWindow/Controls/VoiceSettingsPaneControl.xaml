<UserControl x:Class="Aire.UI.Settings.Controls.VoiceSettingsPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0 8 0 0">
        <StackPanel x:Name="PART_VoiceSection"
                    Margin="4 8 4 16" MaxWidth="480" HorizontalAlignment="Left">

            <TextBlock x:Name="PART_VoiceVoiceLabel"
                       Text="Voice"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       Margin="0 0 0 6" />
            <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                <ComboBox x:Name="PART_VoiceComboBox"
                          Width="290"
                          SelectionChanged="VoiceComboBox_SelectionChanged" />
                <Button x:Name="PART_TestVoiceButton"
                        Content="&#x1F50A;"
                        Width="34" Height="34"
                        Padding="0"
                        Margin="4 0 0 0"
                        ToolTip="Test selected voice"
                        Click="TestVoiceButton_Click" />
            </StackPanel>

            <Border x:Name="PART_VoiceTestErrorBorder"
                    Visibility="Collapsed"
                    Background="{DynamicResource Surface2Brush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10 8"
                    Margin="0 0 0 12">
                <TextBlock x:Name="PART_VoiceTestErrorText"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </Border>

            <CheckBox x:Name="PART_VoiceLocalOnlyCheckBox"
                      Content="Use local voices only (no internet required)"
                      Margin="0 0 0 4"
                      Checked="VoiceLocalOnlyCheckBox_Changed"
                      Unchecked="VoiceLocalOnlyCheckBox_Changed" />

            <Button x:Name="PART_DownloadVoicesButton"
                    Content="Download Windows voices..."
                    HorizontalAlignment="Left"
                    Padding="10 6"
                    Margin="0 0 0 20"
                    Click="DownloadVoicesButton_Click" />

            <TextBlock x:Name="PART_VoiceSpeedLabel"
                       Text="Speed"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       Margin="0 0 0 6" />
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PART_VoiceSpeedDecreaseButton"
                        Content="&#x2212;"
                        Width="34" Height="34"
                        Padding="0"
                        Margin="0 0 4 0"
                        Click="VoiceSpeedDecreaseButton_Click" />
                <TextBlock x:Name="PART_VoiceSpeedDisplay"
                           Width="44"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextBrush}" />
                <Button x:Name="PART_VoiceSpeedIncreaseButton"
                        Content="+"
                        Width="34" Height="34"
                        Padding="0"
                        Margin="4 0 0 0"
                        Click="VoiceSpeedIncreaseButton_Click" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
