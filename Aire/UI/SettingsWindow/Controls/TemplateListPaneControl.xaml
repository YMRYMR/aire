<UserControl x:Class="Aire.UI.Settings.Controls.TemplateListPaneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid ClipToBounds="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="260" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0 0 1 0"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="8 8 8 4">
                    <TextBlock x:Name="PART_ListTitle"
                               Text="Templates"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="PART_ListSubtitle"
                               Text="Reusable prompts and slash shortcuts."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,2,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button x:Name="PART_AddTemplateButton"
                        Grid.Row="1"
                        Content="+ Add template"
                        Click="AddTemplateButton_Click"
                        Padding="12 7"
                        Margin="8 0 8 10" />

                <ListBox x:Name="PART_TemplatesListView"
                         Grid.Row="2"
                         Margin="4 0 4 4"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         SelectionChanged="TemplatesListView_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10 8" />
                            <Setter Property="Margin" Value="4 1" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface2Brush}" />
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface3Brush}" />
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                        <Setter TargetName="Bd" Property="BorderThickness" Value="1.5" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Shortcut}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               Margin="0 2 0 0"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Shortcut}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Shortcut}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <Button x:Name="PART_DeleteTemplateButton"
                                        Grid.Column="1"
                                        Content="×"
                                        FontSize="14"
                                        Padding="8 2"
                                        VerticalAlignment="Center"
                                        Tag="{Binding}"
                                        Click="DeleteTemplate_Click"
                                        Cursor="Hand"
                                        ToolTip="Delete template" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      Background="Transparent" />

        <Border Grid.Column="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Scrollable editor area (steps 1-2) -->
                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid x:Name="PART_EditPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="PART_EditPanelTitle"
                                   Grid.Row="0"
                                   Text="Select a template"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0 0 0 4" />

                        <TextBlock x:Name="PART_EditPanelSubtitle"
                                   Grid.Row="1"
                                   Text="Pick a starter, try it with sample text, then save."
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0 0 0 18" />

                        <Border Grid.Row="2"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14 12"
                                Margin="0 0 0 16"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="PART_StarterTitle"
                                           Text="1. Pick a starter"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0 0 0 6" />
                                <TextBlock x:Name="PART_StarterDescription"
                                           Text="Choose a simple recipe. Aire fills in the template for you."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="0 0 0 10" />

                                <WrapPanel Margin="0 0 0 10">
                                    <Button x:Name="PART_ExplainRecipeButton"
                                            Content="Start explain template"
                                            Click="ApplyExplainRecipe_Click"
                                            Padding="12 6"
                                            Margin="0 0 8 8" />
                                    <Button x:Name="PART_FixRecipeButton"
                                            Content="Start fix template"
                                            Click="ApplyFixRecipe_Click"
                                            Padding="12 6"
                                            Margin="0 0 8 8" />
                                    <Button x:Name="PART_SummarizeRecipeButton"
                                            Content="Start summarize template"
                                            Click="ApplySummarizeRecipe_Click"
                                            Padding="12 6"
                                            Margin="0 0 8 8" />
                                    <Button x:Name="PART_ReviewRecipeButton"
                                            Content="Start review template"
                                            Click="ApplyReviewRecipe_Click"
                                            Padding="12 6"
                                            Margin="0 0 8 8" />
                                </WrapPanel>

                                <TextBlock x:Name="PART_StarterHint"
                                           Text="You can still rename it and change every word."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3"
                              Margin="0 0 0 18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="PART_NameLabel"
                                           Text="Name"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0 0 0 4" />
                                <TextBox x:Name="PART_NameTextBox"
                                         TextChanged="TemplateField_TextChanged" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="PART_ShortcutLabel"
                                           Text="Shortcut"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0 0 0 4" />
                                <TextBox x:Name="PART_ShortcutTextBox"
                                         TextChanged="TemplateField_TextChanged" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="4" Margin="0 0 0 12">
                            <TextBlock x:Name="PART_PrefixLabel"
                                       Text="Extra note for Aire"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0 0 0 4" />
                            <TextBlock x:Name="PART_PrefixDescription"
                                       Text="Optional text Aire adds before the template."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       Margin="0 0 0 6"
                                       TextWrapping="Wrap" />
                            <TextBox x:Name="PART_PrefixTextBox"
                                     TextChanged="TemplateField_TextChanged" />
                        </StackPanel>

                        <Border Grid.Row="5"
                                Background="{DynamicResource Surface2Brush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14 12"
                                Margin="0 0 0 8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="PART_BodyStepTitle"
                                           Grid.Row="0"
                                           Text="2. Write the template"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0 0 0 6" />

                                <WrapPanel Grid.Row="1" Margin="0 0 0 6">
                                    <Button Content="{}{{code}}"
                                            Click="InsertPlaceholder_Click"
                                            Tag="{}{{code}}"
                                            Padding="8 3"
                                            Margin="0 0 4 4"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            ToolTip="Insert code snippet placeholder" />
                                    <Button Content="{}{{text}}"
                                            Click="InsertPlaceholder_Click"
                                            Tag="{}{{text}}"
                                            Padding="8 3"
                                            Margin="0 0 4 4"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            ToolTip="Insert text placeholder" />
                                    <Button Content="{}{{selection}}"
                                            Click="InsertPlaceholder_Click"
                                            Tag="{}{{selection}}"
                                            Padding="8 3"
                                            Margin="0 0 4 4"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            ToolTip="Insert selected text placeholder" />
                                    <Button Content="{}{{clipboard}}"
                                            Click="InsertPlaceholder_Click"
                                            Tag="{}{{clipboard}}"
                                            Padding="8 3"
                                            Margin="0 0 4 4"
                                            FontFamily="Consolas"
                                            FontSize="11"
                                            ToolTip="Insert clipboard content placeholder" />
                                </WrapPanel>

                                <Grid Grid.Row="2" MinHeight="120">
                                    <TextBox x:Name="PART_TemplateTextBox"
                                             AcceptsReturn="True"
                                             AcceptsTab="True"
                                             VerticalAlignment="Stretch"
                                             VerticalContentAlignment="Top"
                                             Cursor="IBeam"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             TextChanged="TemplateField_TextChanged"
                                             MinHeight="120" />
                                    <TextBlock x:Name="PART_TemplateWatermark"
                                               Margin="12 9"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Opacity="0.72"
                                               FontStyle="Italic"
                                               IsHitTestVisible="False"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <!-- Pinned preview area -->
                <Border Grid.Row="1"
                        Background="{DynamicResource Surface2Brush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14 12"
                        Margin="0 8 0 0">
                    <StackPanel>
                        <Grid Margin="0 0 0 6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="PART_TestStepTitle"
                                           Text="3. Test it"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Margin="0 0 0 4" />
                                <TextBlock x:Name="PART_TestStepDescription"
                                           Text="Type sample text to see the preview update live."
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <WrapPanel Grid.Column="1" VerticalAlignment="Center" Margin="0 0 8 0">
                                <Button x:Name="PART_CodeExampleButton"
                                        Content="Code sample"
                                        Click="FillCodeExample_Click"
                                        Padding="10 5"
                                        Margin="0 0 4 0" />
                                <Button x:Name="PART_TextExampleButton"
                                        Content="Text sample"
                                        Click="FillTextExample_Click"
                                        Padding="10 5" />
                            </WrapPanel>

                            <Button x:Name="PART_SaveButton"
                                    Grid.Column="2"
                                    Content="Save"
                                    IsEnabled="True"
                                    Click="SaveButton_Click"
                                    Padding="14 7"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="PART_SampleTextBox"
                                     Grid.Column="0"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="70"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="TemplateField_TextChanged"
                                     ToolTip="Sample input for testing. Not saved." />

                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="PART_PreviewHeading"
                                           Text="What Aire will say"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0 0 0 4" />
                                <Border Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10 8"
                                        MaxHeight="60">
                                    <TextBlock x:Name="PART_PreviewText"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="Select a template to see a preview" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
