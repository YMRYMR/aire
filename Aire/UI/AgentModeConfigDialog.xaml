<Window x:Class="Aire.UI.AgentModeConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orchestrator Mode"
        SizeToContent="Height"
        Width="520"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AccentSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="0 0 0 1"
                    Padding="14 10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleBarText"
                           Text="Orchestrator Mode configuration"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold" />
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="14"
                          MaxHeight="520">
                <StackPanel>
                    <TextBlock x:Name="GoalsLabel"
                               Text="Goals"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0 0 6 0" />
                    <Grid Height="120">
                        <TextBox x:Name="GoalsTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         Cursor="IBeam"
                         Padding="8 6"
                         FontSize="13"
                         Text="" />
                        <TextBlock x:Name="GoalsWatermark"
                                   Margin="12 9"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Opacity="0.72"
                                   FontStyle="Italic"
                                   IsHitTestVisible="False"
                                   TextWrapping="Wrap" />
                    </Grid>
                    <TextBlock x:Name="GoalsDescriptionText"
                               Text="Write one goal per line. The orchestrator will keep track of them while it runs."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0 6 0 14" />

                    <TextBlock x:Name="BudgetLabel"
                               Text="Token budget (0 = unlimited):"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0 0 6 0" />
                    <TextBox x:Name="BudgetTextBox"
                             Text="0"
                             Width="120"
                             HorizontalAlignment="Left"
                             Padding="8 6"
                             FontSize="13"
                             TextAlignment="Right" />

                    <TextBlock x:Name="CategoriesLabel"
                               Text="Allowed tool categories"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0 14 0 6" />
                    <TextBlock x:Name="CategoriesDescriptionText"
                               Text="Leave everything checked if you want the orchestrator to handle the full goal flow."
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0 0 0 8" />
                    <WrapPanel x:Name="CategoryPanel">
                        <CheckBox x:Name="CatFiles" Content="Files" IsChecked="True" Margin="0 0 14 8" />
                        <CheckBox x:Name="CatBrowser" Content="Browser" IsChecked="True" Margin="0 0 14 8" />
                        <CheckBox x:Name="CatAgent" Content="Agent" IsChecked="True" Margin="0 0 14 8" />
                        <CheckBox x:Name="CatMouse" Content="Mouse" IsChecked="True" Margin="0 0 14 8" />
                        <CheckBox x:Name="CatKeyboard" Content="Keyboard" IsChecked="True" Margin="0 0 14 8" />
                        <CheckBox x:Name="CatSystem" Content="System" IsChecked="True" Margin="0 0 14 8" />
                        <CheckBox x:Name="CatEmail" Content="Email" IsChecked="True" Margin="0 0 14 8" />
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0 16 0 0">
                        <Button x:Name="StartButton"
                                Content="Start"
                                Width="90"
                                Margin="0 0 8 0"
                                Click="StartButton_Click" />
                        <Button x:Name="CancelButton"
                                Content="Cancel"
                                Width="90"
                                Click="CancelButton_Click" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
