<Window x:Class="Aire.UI.AgentModeConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Mode"
        SizeToContent="Height"
        Width="340"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource AccentSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="0 0 0 1"
                    Padding="14 10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="Agent Mode Configuration"
                           Foreground="{DynamicResource TextBrush}"
                           FontWeight="SemiBold" />
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="14">
                <TextBlock Text="Token budget (0 = unlimited):"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0 0 6 0" />
                <TextBox x:Name="BudgetTextBox"
                         Text="0"
                         Width="120"
                         HorizontalAlignment="Left"
                         Padding="8 6"
                         FontSize="13"
                         TextAlignment="Right" />

                <TextBlock Text="Tool categories (leave empty for all):"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12"
                           Margin="0 14 0 6" />
                <StackPanel x:Name="CategoryPanel"
                            Orientation="Vertical">
                    <CheckBox x:Name="CatFile" Content="File operations" IsChecked="True" Margin="0 0 0 4" />
                    <CheckBox x:Name="CatSystem" Content="System commands" IsChecked="True" Margin="0 0 0 4" />
                    <CheckBox x:Name="CatWeb" Content="Web access" IsChecked="True" Margin="0 0 0 4" />
                    <CheckBox x:Name="CatScreenshot" Content="Screenshots" IsChecked="True" Margin="0 0 0 4" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 16 0 0">
                    <Button x:Name="StartButton"
                            Content="Start"
                            Width="80"
                            Margin="0 0 8 0"
                            Click="StartButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Width="80"
                            Click="CancelButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
