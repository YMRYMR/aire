<Window x:Class="Aire.UI.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aire Update"
        Width="560"
        MinWidth="460"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource AccentSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="0 0 0 1"
                    Padding="14 10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               Text="Aire update available"
                               Foreground="{DynamicResource TextBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Content="&#x2715;"
                            ToolTip="Close"
                            Width="34"
                            Height="34"
                            Padding="0"
                            Click="LaterButton_Click" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1"
                        Margin="18"
                        Orientation="Vertical">
                <TextBlock x:Name="HeadlineText"
                           Text="A newer Aire version is ready."
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="VersionText"
                           Margin="0 8 0 0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />

                <Border Margin="0 16 0 0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <ScrollViewer MaxHeight="220"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="NotesText"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 18 0 0">
                    <Button x:Name="LaterButton"
                            Content="Later"
                            Width="84"
                            Margin="0 0 8 0"
                            Click="LaterButton_Click" />
                    <Button x:Name="ReleaseNotesButton"
                            Content="Release page"
                            Width="110"
                            Margin="0 0 8 0"
                            Click="ReleaseNotesButton_Click" />
                    <Button x:Name="InstallButton"
                            Content="Install now"
                            Width="104"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Click="InstallButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
