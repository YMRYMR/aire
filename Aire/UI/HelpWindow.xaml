<Window x:Class="Aire.UI.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aire Help"
        Width="600" MinWidth="420"
        Height="720" MinHeight="500"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" ResizeBorderThickness="4" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- Title bar -->
                <RowDefinition Height="Auto" />  <!-- Search bar -->
                <RowDefinition Height="Auto" />  <!-- Tab strip -->
                <RowDefinition Height="*" />     <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource AccentSurfaceBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="0 0 0 1"
                    Padding="14 10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               Text="Help — Aire"
                               Foreground="{DynamicResource AccentTextBrush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Content="&#x2715;"
                            ToolTip="Close"
                            Width="34" Height="34"
                            Padding="0"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>

            <!-- Search bar -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0 0 0 1"
                    Padding="12 7">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox x:Name="SearchBox"
                                 Padding="8 5"
                                 FontSize="13"
                                 TextChanged="SearchBox_TextChanged" />
                        <TextBlock x:Name="SearchPlaceholder"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13"
                                   Padding="10 5"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <Button x:Name="ClearSearchButton"
                            Grid.Column="1"
                            Content="&#x2715;"
                            Width="28" Height="28"
                            Margin="6 0 0 0"
                            Padding="0"
                            FontSize="11"
                            Visibility="Collapsed"
                            Click="ClearSearchButton_Click" />
                </Grid>
            </Border>

            <!-- Tab strip -->
            <Border x:Name="TabStrip"
                    Grid.Row="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0 0 0 1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TabButtonsPanel"
                                Orientation="Horizontal"
                                Margin="6 0" />
                </ScrollViewer>
            </Border>

            <!-- Content -->
            <ScrollViewer x:Name="ContentScroller"
                          Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          Padding="20 16 20 20">
                <StackPanel x:Name="HelpContentPanel" />
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
