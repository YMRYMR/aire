<Window x:Class="Aire.UI.InitializationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aire"
        Width="400" Height="220"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        FontSize="13"
        Background="{DynamicResource BackgroundBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1" CornerRadius="16">
        <Grid Margin="28 22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Aire"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 6" />

            <TextBlock Grid.Row="1"
                       x:Name="StatusText"
                       Text="Starting…"
                       FontSize="11"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 14" />

            <ProgressBar Grid.Row="2"
                         x:Name="InitProgressBar"
                         IsIndeterminate="True"
                         Height="4"
                         Foreground="{DynamicResource PrimaryHoverBrush}"
                         Margin="10 0 10 14" />

            <Border Grid.Row="3"
                    Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ActionItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0 0 0 6">
                                    <Border Width="6"
                                            Height="6"
                                            CornerRadius="3"
                                            Background="{DynamicResource PrimaryHoverBrush}"
                                            Margin="0 5 8 0"
                                            VerticalAlignment="Top" />
                                    <TextBlock Text="{Binding}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
